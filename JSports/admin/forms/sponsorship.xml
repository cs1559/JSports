<?xml version="1.0" encoding="utf-8"?>
<form>

		<fieldset addfieldprefix="FP4P\Component\JSports\Administrator\Fields" 
			name="details" label="COM_JSPORTS_DETAILS">

		<field name="id" type="number" label="JGLOBAL_FIELD_ID_LABEL"
			default="0" class="readonly" readonly="true" />

		<field name="sponsorid" type="hidden" label="COM_JSPORTS_SPONSORID" required="true" />
			
		<field name="startdate" type="calendar"
			label="COM_JSPORTS_STARTDATE"  
			format="%Y-%m-%d"    
			showtime="false"
    		filter="none"/>

		<field name="enddate" type="calendar"
			label="COM_JSPORTS_ENDDATE"
			format="%Y-%m-%d"  
		    showtime="false"
  			filter="none"/>
			
			<field name="programid" type="sql" 
			label="COM_JSPORTS_PROGRAM"
			query="SELECT id, name FROM #__jsports_programs where status &lt;&gt; 'C' order by id desc"
			key_field="id"
			value_field="name" 
			header="-Select Program-"
		/>		
			
		<field name="plancode" type="sql"
			label="COM_JSPORTS_SPONSORSHIP_LEVEL" class="" default="B"
			query="SELECT plancode, name FROM #__jsports_sponsorship_plans order by ordering desc, name"
			key_field="plancode"
			value_field="name" 
			header="-Select Plan">
		</field>
	
		<field name="plantype" type="list"
			label="COM_JSPORTS_SPONSORSHIP_TYPE" class="" default="L"
			validate="options">
			<option value="L">League</option>
			<option value="D">Division</option>
			<option value="T">Team</option>
		</field>		

		<field name="published" type="list" label="JSTATUS"
			class="form-select-color-state" default="1" validate="options">
			<option value="1">JPUBLISHED</option>
			<option value="0">JUNPUBLISHED</option>
			<option value="2">JARCHIVED</option>
			<option value="-2">JTRASHED</option>
		</field>					
	</fieldset>


</form>